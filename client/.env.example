# Optional: set when the app is built for production and the API is on another URL.
# Leave unset for local dev (Vite proxies /api to 127.0.0.1:3001 — avoids Windows DNS ENOBUFS with "localhost").
# No trailing slash.
# VITE_API_URL=https://your-api.onrender.com
# VITE_API_URL=https://abc123.ngrok-free.app

# When you run the API on a non-default port (e.g. PORT=3002 npm start), match it here for `cd client && npm run dev`:
# VITE_API_PROXY_PORT=3002
