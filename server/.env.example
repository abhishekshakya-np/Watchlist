# Optional: API keys for "Look up online" (Add/Edit title) and for season list in Add related title.
# TMDB (movies, series, and season list): get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=
# Games: https://rawg.io/apidocs
# RAWG_API_KEY=your_rawg_key
# Books: Open Library (no key needed)

# Optional: daily Telegram backup (see root .env.example for TELEGRAM_* vars)

# Dev only — Vite cache files client/vite.config.js.timestamp-*.mjs: all are cleared on dev start; while running, extras are removed (newest kept). Disable repeat cleanup:
# VITE_TIMESTAMP_CLEANUP_DISABLED=1
# VITE_TIMESTAMP_CLEANUP_FIRST_DELAY_MS=90000   # first “keep newest only” pass after start (default 90s)
# VITE_TIMESTAMP_CLEANUP_INTERVAL_MS=120000     # repeat every N ms (default 2 min)
