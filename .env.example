# Admin (optional): when set, changing data (titles, list, bookmarks, backup) requires signing in at /admin/login.
# Generate a long random password. Set ADMIN_SESSION_SECRET in production for stable cookie signing.
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=

# Optional: API keys (server loads from root or server/). Copy to .env and fill in.
# TMDB (movies, series, season list): https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Optional: daily Telegram backup. Bot from @BotFather → TELEGRAM_BOT_TOKEN. Your numeric user id → TELEGRAM_CHAT_ID (e.g. t.me/userinfobot), or message YOUR bot then run: cd server && npm run telegram-chat-id
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_BACKUP_CRON=0 4 * * *
# TELEGRAM_BACKUP_TIMEZONE=America/New_York
#
# Quick test (optional): set to 1 to send one backup when the server starts (useful locally; avoid on Render if you redeploy often).
# TELEGRAM_BACKUP_ON_START=1
#
# Optional: POST /api/backup/trigger-telegram when the SPA loads (first fetch per cooldown). Cooldown default 300s.
# Works without admin login so backups still run when ADMIN_PASSWORD is set (export/restore stay admin-only).
# TELEGRAM_BACKUP_ON_BROWSER_OPEN=1
# TELEGRAM_BACKUP_BROWSER_COOLDOWN_SEC=300
# TELEGRAM_BACKUP_BROWSER_SECRET=  # if set, client must send header X-Watchlist-Telegram-Secret (not for public browser builds)
